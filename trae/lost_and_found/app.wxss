/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #f5f5f5;
  color: #333;
}

.container {
  padding: 16rpx;
}

.card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.btn {
  background-color: #1989fa;
  color: #fff;
  border-radius: 8rpx;
  padding: 16rpx;
  text-align: center;
  font-size: 32rpx;
  margin-top: 20rpx;
}

.input {
  border: 1rpx solid #eaeaea;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  font-size: 32rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.image {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  object-fit: cover;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: #f0f0f0;
  border-radius: 16rpx;
  font-size: 24rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.flex {
  display: flex;
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.mt-10 {
  margin-top: 10rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.text-center {
  text-align: center;
}

.text-gray {
  color: #999;
}

.text-sm {
  font-size: 24rpx;
}