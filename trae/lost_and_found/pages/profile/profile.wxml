<view class="container">
  <!-- 用户信息 -->
  <view class="card">
    <view class="flex align-center">
      <image class="avatar" src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=user%20avatar%20placeholder&image_size=square" mode="aspectFill"></image>
      <view class="ml-10">
        <view class="title">{{userInfo.nickName || '未登录'}}</view>
        <view class="text-gray">点击登录</view>
      </view>
    </view>
  </view>
  
  <!-- 功能菜单 -->
  <view class="card mt-10">
    <view class="menu-item" bindtap="navigateToMyPosts">
      <view class="flex justify-between align-center">
        <view>我的发布</view>
        <view class="text-gray">→</view>
      </view>
    </view>
    <view class="menu-item">
      <view class="flex justify-between align-center">
        <view>我的收藏</view>
        <view class="text-gray">→</view>
      </view>
    </view>
    <view class="menu-item">
      <view class="flex justify-between align-center">
        <view>设置</view>
        <view class="text-gray">→</view>
      </view>
    </view>
    <view class="menu-item">
      <view class="flex justify-between align-center">
        <view>关于我们</view>
        <view class="text-gray">→</view>
      </view>
    </view>
  </view>
  
  <!-- 版本信息 -->
  <view class="text-center text-gray text-sm mt-20">
    版本 1.0.0
  </view>
</view>